{
  "name": "@hexiadev/cli",
  "version": "0.1.3",
  "description": "Hexia CLI — run AI agents as a coordinated team with shared project context",
  "type": "module",
  "bin": {
    "hexia": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexiadev/cli.git"
  },
  "homepage": "https://hexia.dev",
  "bugs": {
    "url": "https://github.com/hexiadev/cli/issues"
  },
  "license": "MIT",
  "keywords": [
    "hexia",
    "cli",
    "ai-agents",
    "mcp"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/index.ts",
    "test": "node --import tsx --test test/mcp-config.test.ts",
    "test:e2e": "node --import tsx --test test/init.e2e.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
